generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String   @unique
  phone        String?
  avatarUrl    String?
  workplace    Workplace?
  profession   String?
  title        String?
  passwordHash String
  role         Role     @default(CAREGIVER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  caregivers PatientCaregiver[]
  sessions   UserSession[]
  createdRooms Room[]
  roomMembers  RoomMember[]
  createdThreads Thread[]
  authoredMessages Message[]
  doctorPatients        DoctorPatient[]
  anamnezeEntries       Anamneze[]
  assignedTreatments    Treatment[]
  doctorNotes           DoctorNote[]
  notifications         AppNotification[]
  sentNotifications     AppNotification[] @relation("NotificationActor")
}

model UserSession {
  id               String   @id @default(cuid())
  userId           String
  refreshTokenHash String
  userAgent        String?
  ip               String?
  createdAt        DateTime @default(now())
  expiresAt        DateTime
  revokedAt        DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Patient {
  id          String    @id @default(cuid())
  firstName   String
  lastName    String
  birthDate   DateTime?
  avatarUrl   String?
  shortIntro  String?
  maritalDate DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  caregivers  PatientCaregiver[]
  reminders   Reminder[]
  contacts    Contact[]
  devices     Device[]
  PairingCode PairingCode[]
  doctorAssignments DoctorPatient[]
  anamnezeEntries   Anamneze[]
  clockTests        ClockTest[]
  mmseTests         MMSETest[]
  treatments        Treatment[]
  doctorNotes       DoctorNote[]
  notifications     AppNotification[]
}

model PatientCaregiver {
  id          String        @id @default(cuid())
  patientId   String
  caregiverId String
  role        CaregiverRole @default(OWNER)
  createdAt   DateTime      @default(now())

  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  caregiver User    @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  @@unique([patientId, caregiverId])
}

model PairingCode {
  id        String    @id @default(cuid())
  patientId String
  code      String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdBy String // caregiver user id
  createdAt DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
}

model Device {
  id               String    @id @default(cuid())
  patientId        String
  platform         String // ios | android | web
  devicePublicId   String
  deviceName       String?
  refreshTokenHash String?
  isPrimary        Boolean   @default(false)
  lastSeenAt       DateTime?
  createdAt        DateTime  @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([patientId, devicePublicId])
  @@index([patientId])
}

model Reminder {
  id          String    @id @default(cuid())
  patientId   String
  type        String // PILLS | DOOR_LOCK | TEETH | PET_CARE | CUSTOM
  title       String
  notes       String?
  schedule    String? // cron arba HH:MM
  isActive    Boolean   @default(true)
  lastFiredAt DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

model Contact {
  id        String   @id @default(cuid())
  patientId String
  relation  String // SISTER | SPOUSE | CHILD | FRIEND | OTHER
  name      String
  phone     String
  photoUrl  String?
  description String?
  isEmergencyContact Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
}

enum Role {
  CAREGIVER
  PATIENT
  DOCTOR
  ADMIN
}

enum Workplace {
  LSMUKK
  KLAIPEDOS_LIGONINE
  VU_LIGONINE
}

enum CaregiverRole {
  OWNER
  EDITOR
  VIEWER
}

enum RoomVisibility {
  PRIVATE
  PUBLIC
}

enum RoomMemberRole {
  OWNER
  MODERATOR
  MEMBER
}

model Room {
  id           String          @id @default(cuid())
  name         String
  visibility   RoomVisibility  @default(PRIVATE)
  createdById  String
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  createdBy    User            @relation(fields: [createdById], references: [id], onDelete: Cascade)
  members      RoomMember[]
  threads      Thread[]

  @@index([createdById])
}

model RoomMember {
  id       String          @id @default(cuid())
  roomId   String
  userId   String
  role     RoomMemberRole  @default(MEMBER)
  joinedAt DateTime        @default(now())

  room     Room @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user     User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([roomId, userId])
  @@index([userId])
}

model Thread {
  id          String   @id @default(cuid())
  roomId      String
  title       String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  messages    Message[]

  @@index([roomId])
}

model Message {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  content   String
  editedAt  DateTime?
  createdAt DateTime @default(now())

  thread    Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author    User   @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([threadId])
  @@index([authorId])
}

model AiConversation {
  id        String                @id @default(cuid())
  ownerId   String
  ownerRole AiOwnerRole
  patientId String?
  title     String?
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  messages  AiConversationMessage[]

  @@index([ownerId, ownerRole, updatedAt])
  @@index([patientId])
}

model AiConversationMessage {
  id              String        @id @default(cuid())
  conversationId  String
  role            AiMessageRole
  content         String
  contactSnapshot Json?
  createdAt       DateTime      @default(now())

  conversation AiConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

enum AiOwnerRole {
  CAREGIVER
  PATIENT
  ADMIN
}

enum AiMessageRole {
  USER
  ASSISTANT
}

enum DoctorPatientStatus {
  ACTIVE
  ARCHIVED
}

model DoctorPatient {
  id         String              @id @default(cuid())
  doctorId   String
  patientId  String
  status     DoctorPatientStatus @default(ACTIVE)
  assignedAt DateTime            @default(now())
  updatedAt  DateTime            @updatedAt

  doctor User    @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@unique([doctorId, patientId])
  @@index([doctorId, status])
  @@index([patientId])
}

model Anamneze {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId, updatedAt])
  @@index([doctorId])
}

model ClockTest {
  id        String   @id @default(cuid())
  patientId String
  imageUrl  String
  metadata  Json?
  createdAt DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
}

model MMSETest {
  id                String   @id @default(cuid())
  patientId         String
  score             Int
  answers           Json
  assignedByDoctor  String?
  createdAt         DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@index([assignedByDoctor])
}

model Treatment {
  id          String   @id @default(cuid())
  patientId   String
  doctorId    String
  description String
  createdAt   DateTime @default(now())

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId, createdAt])
  @@index([doctorId])
}

model DoctorNote {
  id        String   @id @default(cuid())
  patientId String
  doctorId  String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctor  User    @relation(fields: [doctorId], references: [id], onDelete: Cascade)

  @@index([patientId, updatedAt])
  @@index([doctorId])
}

model AppNotification {
  id        String   @id @default(cuid())
  userId    String?
  patientId String?
  title     String
  body      String
  type      String
  isRead    Boolean  @default(false)
  actorId   String?
  metadata  Json?
  createdAt DateTime @default(now())

  user    User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  patient Patient? @relation(fields: [patientId], references: [id], onDelete: SetNull)
  actor   User?   @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId, isRead, createdAt])
  @@index([patientId])
}
