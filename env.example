# Database
# On Render: use the **Internal** Postgres URL for your web service (Dashboard →
# your Postgres → Connect → Internal). Append ?sslmode=require if connecting
# externally (e.g. Neon). Free-tier Render Postgres may sleep — wake it before deploy.
DATABASE_URL="postgresql://username:password@localhost:5432/memis_db"

# JWT Secrets (use the generated secrets from earlier)
JWT_ACCESS_SECRET=e55e7a1338efe8e7961c431924ad5a38eaeef066c227a87d9128df56306d9fe517c321d8727268a5a9d39de1ad25b8a9296a8d68fb6bfd403a508a7c0b45cd6d
JWT_REFRESH_SECRET=9262d52192ffe345cbbd98a4fc6b94d51f6350959d2cfede24e2bae9d07e52351d776398deb1f9caef0cf111a63ec3b5e43193d1159d1d44c2ab4c4e937d4a67

# Access token lifetime (short for security). Defaults to 30m if unset.
JWT_ACCESS_TTL=30m

# Comma-separated list of allowed CORS origins (web app, marketing site, etc.)
# Leave empty to allow all origins in development only.
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,https://memis.app

# Public base URL of the app/website used in email links (verification, reset)
APP_PUBLIC_URL=https://memis.app

# Email (Resend) - https://resend.com
RESEND_API_KEY=
MAIL_FROM="Memis <no-reply@memis.app>"

# Google Gemini API key (powers the MemiMinds AI companion + clinical drafts).
# Create one at https://aistudio.google.com/app/apikey . Use a PAID/billing-
# enabled key so prompt content is NOT used to train Google's models.
GEMINI_API_KEY=

# Custom deep-link scheme used in verification / password-reset email links so
# they open directly in the app (e.g. memis://reset-password?token=...).
APP_DEEP_LINK_SCHEME=memis

# Billing
# RevenueCat webhook Authorization header value (Bearer <secret>)
REVENUECAT_WEBHOOK_SECRET=
# Stripe (web/PWA checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Firebase Cloud Messaging (Android push). Provide ONE of the following.
# SECURITY: never commit the service-account JSON. The previously committed key
# (memis-703f2-firebase-adminsdk-*.json) has been removed and MUST be rotated in
# the Google Cloud console. Prefer FCM_SERVICE_ACCOUNT_JSON (single-line JSON).
FCM_SERVICE_ACCOUNT_JSON=
# Or a path to the key file mounted as a secret (not committed):
FCM_SERVICE_ACCOUNT_PATH=

# Timezone used by the server-side reminder scheduler to interpret the HH:mm
# schedule strings (which are stored without a timezone). Defaults to
# Europe/Vilnius. Use an IANA timezone name.
APP_TIMEZONE=Europe/Vilnius

# Reminders are delivered by on-device local notifications (reliable in the
# background/when killed). The server keeps the caregiver 24h-inactivity alert
# regardless. Only set this to "true" if you need the server to ALSO push
# reminders (e.g. a build that cannot schedule local notifications) — note this
# can cause the patient to receive each reminder twice.
REMINDER_SERVER_PUSH=false

